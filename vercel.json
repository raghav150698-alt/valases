{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npx --yes pnpm@10.15.1 --dir app/web_assessment_react install --frozen-lockfile && npm --prefix app/web_assessment_react run build",
  "functions": {
    "api/index.py": {
      "includeFiles": "app/web_assessment_react/dist/**"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/api/index" },
    { "src": "/media/(.*)", "dest": "/api/index" },
    { "src": "/(.*)", "dest": "/api/index" }
  ]
}
