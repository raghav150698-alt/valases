APP_DOMAIN=your-domain.com
ACME_EMAIL=admin@your-domain.com
GNUCASH_SCREEN_GEOMETRY=1600x900x24

POSTGRES_DB=valases
POSTGRES_USER=valases
POSTGRES_PASSWORD=replace_with_a_long_random_password

APP_ENV=production
APP_NAME=Valases API
APP_BASE_URL=https://your-domain.com
CANDIDATE_APP_BASE_URL=https://candidate.your-domain.com
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
AUTH_MODE=supabase
ENABLE_AI_REVIEW=false
ALLOW_DEV_ROLE_OVERRIDE=false
ALLOW_SELF_SERVICE_SIGNUP=false
ENABLE_LEGACY_PASSWORD_AUTH=false
ENABLE_ADMIN_RECOVERY=false
ENABLE_SERVER_CODE_EXECUTION=false
ENABLE_SHARED_GRAPH_EXCEL=false
ENABLE_PROCTOR_EVIDENCE_UPLOAD=false
ENABLE_STARTUP_DATABASE_MANAGEMENT=false
ENFORCE_PRODUCTION_SECURITY=true

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_server_only_supabase_secret_key

FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

OBJECT_STORAGE_BACKEND=s3
AWS_REGION=
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_ACCESS_KEY=
BUNNY_STORAGE_ENDPOINT=storage.bunnycdn.com
BUNNY_STORAGE_PULL_ZONE=
BUNNY_STORAGE_UPLOAD_TIMEOUT_SECONDS=900
BUNNY_STORAGE_UPLOAD_RETRIES=3

BUNNY_STREAM_LIBRARY_ID=0
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_PULL_ZONE=
BUNNY_STREAM_EMBED_TOKEN_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=noreply@your-domain.com
ADMIN_EMAILS=admin@your-domain.com

CORS_ALLOW_ORIGINS=https://candidate.your-domain.com
TRUSTED_HOSTS=your-domain.com
ENABLE_GZIP=true
GZIP_MINIMUM_SIZE=1024
SECURITY_ENABLE_CSP=true
SECURITY_CSP_FRAME_ANCESTORS='none'
SECURITY_CSP_EXTRA=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=180
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=35
MAX_REQUEST_BODY_BYTES=4000000
MAX_PROCTOR_EVIDENCE_BYTES=8000000
OPS_ENABLE_REQUEST_LOGS=true
OPS_SLOW_REQUEST_MS=1200
