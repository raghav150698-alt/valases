{
  "model": "xgboost",
  "manual_review_threshold": 0.5,
  "warning_threshold": 0.45,
  "critical_threshold": 0.62,
  "auto_deduction_enabled": true,
  "deduction_policy": {
    "per_warning_pct": 2,
    "high_risk_event_pct": 5,
    "max_total_deduction_pct": 12
  },
  "guardrails": {
    "require_two_signals": true,
    "require_min_confidence": 0.7,
    "always_manual_review_if_critical": true,
    "min_holdout_for_auto_deduction": 100
  }
}